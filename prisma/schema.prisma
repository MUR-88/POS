generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id         String     @id @default(cuid())
  name       String
  email      String     @unique
  password   String
  role       Role       @default(KASIR)
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  orders     Order[]
  stockLogs  StockLog[]
  shifts     Shift[]

  @@map("users")
}

enum Role {
  ADMIN
  MANAGER
  KASIR
}

// ─── Menu ─────────────────────────────────────────────────────────────────────

model Category {
  id        String     @id @default(cuid())
  name      String
  icon      String?
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  menuItems MenuItem[]
  discounts Discount[]

  @@map("categories")
}

model MenuItem {
  id          String      @id @default(cuid())
  name        String
  description String?
  price       Decimal     @db.Decimal(12, 0)
  imageUrl    String?
  stock       Int         @default(0)
  minStock    Int         @default(5)
  isAvailable Boolean     @default(true)
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
  stockLogs   StockLog[]
  discounts   Discount[]

  @@map("menu_items")
}

// ─── Tables ───────────────────────────────────────────────────────────────────

model Table {
  id        String      @id @default(cuid())
  number    String      @unique
  capacity  Int         @default(4)
  status    TableStatus @default(AVAILABLE)
  floor     String?
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  orders    Order[]

  @@map("tables")
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
}

// ─── Members ──────────────────────────────────────────────────────────────────

model Member {
  id         String   @id @default(cuid())
  name       String
  phone      String   @unique
  email      String?
  points     Int      @default(0)
  totalSpend Decimal  @db.Decimal(12, 0) @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  orders     Order[]

  @@map("members")
}

// ─── Shifts ───────────────────────────────────────────────────────────────────

model Shift {
  id          String      @id @default(cuid())
  cashierId   String
  cashier     User        @relation(fields: [cashierId], references: [id])
  openedAt    DateTime    @default(now())
  closedAt    DateTime?
  openingCash Decimal     @db.Decimal(12, 0) @default(0)
  closingCash Decimal?    @db.Decimal(12, 0)
  status      ShiftStatus @default(OPEN)
  notes       String?
  orders      Order[]

  @@map("shifts")
}

enum ShiftStatus {
  OPEN
  CLOSED
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id           String      @id @default(cuid())
  orderNo      String      @unique
  tableId      String?
  table        Table?      @relation(fields: [tableId], references: [id])
  tableNo      String?
  customerName String?
  memberId     String?
  member       Member?     @relation(fields: [memberId], references: [id])
  shiftId      String?
  shift        Shift?      @relation(fields: [shiftId], references: [id])
  status       OrderStatus @default(PENDING)
  kdsStatus    KDSStatus   @default(PENDING)
  subtotal     Decimal     @db.Decimal(12, 0)
  discount     Decimal     @db.Decimal(12, 0) @default(0)
  tax          Decimal     @db.Decimal(12, 0) @default(0)
  total        Decimal     @db.Decimal(12, 0)
  payMethod    PayMethod   @default(CASH)
  amountPaid   Decimal     @db.Decimal(12, 0) @default(0)
  change       Decimal     @db.Decimal(12, 0) @default(0)
  notes        String?
  cashierId    String
  cashier      User        @relation(fields: [cashierId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  items        OrderItem[]

  @@map("orders")
}

enum OrderStatus {
  PENDING
  COMPLETED
  VOIDED
  REFUNDED
}

enum KDSStatus {
  PENDING
  PREPARING
  READY
  SERVED
}

enum PayMethod {
  CASH
  QRIS
  TRANSFER
  DEBIT
  KREDIT
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  qty        Int
  price      Decimal  @db.Decimal(12, 0)
  discount   Decimal  @db.Decimal(12, 0) @default(0)
  subtotal   Decimal  @db.Decimal(12, 0)
  notes      String?
  kdsStatus  KDSStatus @default(PENDING)

  @@map("order_items")
}

// ─── Stock ────────────────────────────────────────────────────────────────────

model StockLog {
  id         String    @id @default(cuid())
  menuItemId String
  menuItem   MenuItem  @relation(fields: [menuItemId], references: [id])
  type       StockType
  change     Int
  stockAfter Int
  reason     String?
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  createdAt  DateTime  @default(now())

  @@map("stock_logs")
}

enum StockType {
  SALE
  RESTOCK
  ADJUSTMENT
  VOID
  REFUND
}

// ─── Discounts ────────────────────────────────────────────────────────────────

model Discount {
  id          String         @id @default(cuid())
  name        String
  description String?
  type        DiscountType
  value       Decimal        @db.Decimal(12, 2)
  minOrder    Decimal?       @db.Decimal(12, 0)
  maxDiscount Decimal?       @db.Decimal(12, 0)
  target      DiscountTarget @default(GLOBAL)
  categoryId  String?
  category    Category?      @relation(fields: [categoryId], references: [id])
  menuItemId  String?
  menuItem    MenuItem?      @relation(fields: [menuItemId], references: [id])
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("discounts")
}

enum DiscountType {
  FIXED
  PERCENT
}

enum DiscountTarget {
  GLOBAL
  CATEGORY
  ITEM
}

// ─── Settings ─────────────────────────────────────────────────────────────────

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}
